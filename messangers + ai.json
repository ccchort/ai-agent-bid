        "query": "SELECT \"id\", \"user_id\", \"platform\", \"accumulated_text\", \"client_name\", \"created_at\"\nFROM \"user_sessions\" \nWHERE \"last_message_at\" < NOW() - INTERVAL '5 minutes';",
