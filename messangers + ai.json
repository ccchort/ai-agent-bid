    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH updated AS (\n    UPDATE user_sessions\n    SET \n        accumulated_text = accumulated_text || CHR(10) || '{{ $json.messageText }}',\n        last_message_at = NOW()\n    WHERE user_id = '{{ $json.userId }}'\n      AND last_message_at >= NOW() - INTERVAL '5 minutes'\n    RETURNING id\n)\nINSERT INTO user_sessions (user_id, platform, accumulated_text, last_message_at, client_name)\nSELECT \n    '{{ $json.userId }}', \n    '{{ $json.platform }}', \n    '{{ $json.messageText }}', \n    NOW(),\n    '{{ $json.client_name }}'\nWHERE NOT EXISTS (SELECT 1 FROM updated);\n",
        "options": {}
      },
